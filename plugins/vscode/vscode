#!/usr/bin/env bash

# Previously depended on the `homebrew` plugin (for `brew --prefix`); that
# plugin retired in the nix-darwin slice. The body still calls `brew --prefix`
# at runtime — brew is now a pre-nix prerequisite installed by framework/compat,
# so the path resolves fine; we just don't depend on the plugin existing.
export DOTFILES_VSCODE_DEPS=()

dotfiles_vscode_apply () {
  local code_helper_path
  code_helper_path='/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code'

  if [ ! -f "$code_helper_path" ]; then
    debug "VSCode does not appear to be installed"
    return 0
  fi

  if command -v code > /dev/null 2>&1; then
    debug "VSCode CLI helper already appears to be installed"
    return 0
  fi

  ln -s "$code_helper_path" "$(brew --prefix)/bin/code" >/dev/null 2>&1
}
