{
  "permissions": {
    "defaultMode": "plan"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.40 /System/Library/Sounds/Morse.aiff"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.35 /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true
}