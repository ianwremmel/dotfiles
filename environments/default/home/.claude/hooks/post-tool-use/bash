#!/usr/bin/env -S uv run --quiet --with pyyaml --with bashlex python3
"""PostToolUse hook for Bash command config auto-update.

After a command that required manual approval executes successfully,
this hook offers to add a rule to bash.yml for future auto-approval.
"""

import json
import os
import sys
from datetime import datetime
from pathlib import Path

import yaml

sys.path.insert(0, str(Path(__file__).parent.parent / "lib"))

from bash_common import (
    expand_path,
    get_config_path,
    load_config,
    parse_command,
    split_compound_command,
)


def get_log_path(config: dict) -> Path | None:
    """Get expanded log path from config, or None if logging disabled."""
    logging_config = config.get("logging", {})
    if not logging_config.get("enabled", False):
        return None

    log_path = logging_config.get("path", "")
    if not log_path:
        return None

    return Path(expand_path(log_path))


def find_pending_approval(config: dict, tool_use_id: str) -> dict | None:
    """Find a pending approval entry in the log for the given tool_use_id."""
    log_path = get_log_path(config)
    if not log_path or not log_path.exists():
        return None

    with open(log_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
                if entry.get("tool_use_id") == tool_use_id and entry.get("action") == "ask":
                    return entry
            except json.JSONDecodeError:
                continue

    return None


def add_allow_rule(config_path: Path, command: str) -> bool:
    """Add an allow rule for the given command to the config file.

    Returns True if rule was added, False otherwise.
    """
    segments = split_compound_command(command)

    if not segments:
        return False

    parsed = parse_command(segments[0])
    base_command = parsed["base_command"]
    subcommand = parsed["subcommand"]

    with open(config_path) as f:
        config = yaml.safe_load(f)

    commands = config.setdefault("commands", {})

    if base_command not in commands:
        commands[base_command] = {"action": "allow"}
    else:
        cmd_config = commands[base_command]

        if subcommand:
            subcommands = cmd_config.setdefault("subcommands", {})
            if subcommand not in subcommands:
                subcommands[subcommand] = {"action": "allow"}
            else:
                subcommands[subcommand]["action"] = "allow"
        else:
            cmd_config["action"] = "allow"

    with open(config_path, "w") as f:
        yaml.dump(config, f, default_flow_style=False, sort_keys=False, allow_unicode=True)

    return True


def log_config_update(config: dict, command: str, success: bool) -> None:
    """Log config update action."""
    log_path = get_log_path(config)
    if not log_path:
        return

    log_path.parent.mkdir(parents=True, exist_ok=True)

    timestamp = datetime.now().isoformat()
    log_entry = {
        "timestamp": timestamp,
        "action": "config_update",
        "command": command,
        "success": success,
    }

    with open(log_path, "a") as f:
        f.write(json.dumps(log_entry) + "\n")


def main() -> None:
    """Main entry point for PostToolUse hook."""
    try:
        input_data = json.load(sys.stdin)
    except json.JSONDecodeError:
        return

    tool_input = input_data.get("tool_input", {})
    command = tool_input.get("command", "")
    tool_use_id = input_data.get("tool_use_id")
    tool_result = input_data.get("tool_result", {})

    if not command or not tool_use_id:
        return

    is_error = tool_result.get("is_error", False)
    if is_error:
        return

    try:
        config = load_config()
    except Exception:
        return

    pending = find_pending_approval(config, tool_use_id)

    if not pending:
        return

    segments = split_compound_command(command)
    if not segments:
        return

    parsed = parse_command(segments[0])
    base_command = parsed["base_command"]
    subcommand = parsed["subcommand"]

    if subcommand:
        cmd_display = f"{base_command} {subcommand}"
    else:
        cmd_display = base_command

    print(f"Command '{cmd_display}' was manually approved.", file=sys.stderr)
    print(f"Add allow rule to config? [y/N] ", file=sys.stderr, end="", flush=True)

    try:
        response = input().strip().lower()
    except EOFError:
        response = ""

    if response in ("y", "yes"):
        config_path = get_config_path()
        success = add_allow_rule(config_path, command)
        log_config_update(config, command, success)

        if success:
            print(f"Added allow rule for '{cmd_display}'", file=sys.stderr)
        else:
            print(f"Failed to add rule for '{cmd_display}'", file=sys.stderr)


if __name__ == "__main__":
    main()
