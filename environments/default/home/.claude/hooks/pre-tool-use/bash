#!/usr/bin/env -S uv run --quiet --with pyyaml python3
"""PreToolUse hook for Bash command validation.

Reads JSON from stdin containing tool_input.command, evaluates against
configured rules, and outputs JSON with permission decision.
"""

import json
import os
import sys
from datetime import datetime
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent.parent / "lib"))

from bash_common import evaluate_command, expand_path, load_config


def get_log_path(config: dict) -> Path | None:
    """Get expanded log path from config, or None if logging disabled."""
    logging_config = config.get("logging", {})
    if not logging_config.get("enabled", False):
        return None

    log_path = logging_config.get("path", "")
    if not log_path:
        return None

    return Path(expand_path(log_path))


def log_decision(
    config: dict,
    command: str,
    action: str,
    reason: str,
    tool_use_id: str | None = None,
) -> None:
    """Log command and decision to log file if logging enabled."""
    log_path = get_log_path(config)
    if not log_path:
        return

    log_path.parent.mkdir(parents=True, exist_ok=True)

    timestamp = datetime.now().isoformat()
    log_entry = {
        "timestamp": timestamp,
        "command": command,
        "action": action,
        "reason": reason,
        "tool_use_id": tool_use_id,
    }

    with open(log_path, "a") as f:
        f.write(json.dumps(log_entry) + "\n")


def main() -> None:
    """Main entry point for PreToolUse hook."""
    try:
        input_data = json.load(sys.stdin)
    except json.JSONDecodeError as e:
        output = {
            "permissionDecision": "deny",
            "permissionDecisionReason": f"Failed to parse input JSON: {e}",
        }
        print(json.dumps(output))
        return

    tool_input = input_data.get("tool_input", {})
    command = tool_input.get("command", "")
    tool_use_id = input_data.get("tool_use_id")

    if not command:
        output = {
            "permissionDecision": "deny",
            "permissionDecisionReason": "No command provided",
        }
        print(json.dumps(output))
        return

    try:
        config = load_config()
    except Exception as e:
        output = {
            "permissionDecision": "ask",
            "permissionDecisionReason": f"Failed to load config: {e}",
        }
        print(json.dumps(output))
        return

    result = evaluate_command(command, config)

    action = result["action"]
    reason = result["reason"]

    log_decision(config, command, action, reason, tool_use_id)

    output = {
        "permissionDecision": action,
        "permissionDecisionReason": reason,
    }

    print(json.dumps(output))


if __name__ == "__main__":
    main()
