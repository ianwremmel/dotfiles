#!/usr/bin/env bash

# Nix install + activation logic, sourced directly by ./apply. Depends only on
# framework/logging (log/debug/error) and the
# DOTFILES_{ROOT_DIR,ENVIRONMENT,NIX_SKIP,DARWIN_FORCE} globals.

# Nix install/profile locations differ by OS: macOS uses the multi-user daemon
# install (Determinate); Linux uses a single-user install (no daemon) whose
# profile script and nix binary live under ~/.nix-profile. Detection and
# profile-sourcing branch accordingly. We detect by path (not just `command -v
# nix`) because the framework runs apply hooks in a non-login subshell where nix
# may not be on PATH even when installed.
_dotfiles_nix_profile_script () {
  if [ "$(uname -s)" = Darwin ]; then
    echo /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
  else
    echo "$HOME/.nix-profile/etc/profile.d/nix.sh"
  fi
}

_dotfiles_nix_is_installed () {
  command -v nix >/dev/null 2>&1 \
    || [ -e /nix/var/nix/profiles/default/bin/nix ] \
    || [ -e "$HOME/.nix-profile/bin/nix" ]
}

_dotfiles_nix_load_profile () {
  local script
  script="$(_dotfiles_nix_profile_script)"
  if ! command -v nix >/dev/null 2>&1 && [ -f "$script" ]; then
    # The profile script may reference unset vars; relax `set -u` while sourcing.
    set +u
    # The nix.sh profile script guards its PATH setup on both $HOME and $USER
    # being non-empty. $USER can be absent in minimal containers; supply it.
    USER="${USER:-$(id -un)}"
    export USER
    # shellcheck disable=SC1090
    source "$script"
    set -u
  fi
}

_dotfiles_nix_install () {
  if _dotfiles_nix_is_installed; then
    debug 'nix already installed'
    return 0
  fi
  if [ "$(uname -s)" = Darwin ]; then
    log 'Installing Nix (Determinate Systems installer)'
    curl -fsSL https://install.determinate.systems/nix | sh -s -- install --no-confirm
  else
    # Single-user, no daemon. Download then run with stdin detached so the
    # installer reads the script from the file (not stdin) and cannot block on a
    # prompt in a non-interactive container.
    #
    # When running as root (e.g. in a Docker container), the installer tries to
    # create /nix via sudo, which may not be present. Pre-create /nix so the
    # installer skips that step.
    if [ "$(id -u)" -eq 0 ]; then
      # Pre-create /nix so the installer doesn't need sudo to create it.
      [ -d /nix ] || mkdir -m 0755 /nix
      # Create /etc/nix/nix.conf with build-users-group empty so Nix does not
      # require the nixbld group when running as root (e.g. in a container).
      mkdir -p /etc/nix
      # Match only a real (uncommented) assignment so a commented-out example
      # line doesn't suppress the write; prepend a newline so the setting can't
      # concatenate onto a prior line that lacks a trailing newline.
      if ! grep -Eqs '^[[:space:]]*build-users-group[[:space:]]*=' /etc/nix/nix.conf 2>/dev/null; then
        printf '\nbuild-users-group =\n' >> /etc/nix/nix.conf
      fi
      # Building as root without build users still needs the sandbox: without
      # it, builds run with HOME=/homeless-shelter and fail once a prior build
      # has created that directory. Requires user namespaces (present on the
      # dev-container nodes).
      if ! grep -Eqs '^[[:space:]]*sandbox[[:space:]]*=' /etc/nix/nix.conf 2>/dev/null; then
        # Prepend a newline so this can't concatenate onto a prior line that
        # lacks a trailing newline (matches the build-users-group write above).
        printf '\nsandbox = true\n' >> /etc/nix/nix.conf
      fi
    fi
    log 'Installing Nix (official single-user install, no daemon)'
    local installer
    installer="$(mktemp)"
    curl -fsSL https://nixos.org/nix/install -o "$installer"
    sh "$installer" --no-daemon --no-channel-add < /dev/null
    rm -f "$installer"
  fi
}

_dotfiles_nix_resolve_profile () {
  # Both macOS and Linux populate DOTFILES_ENVIRONMENT via the framework's
  # config_load before this runs (see ./apply), so no per-platform fallback
  # is needed.
  echo "${DOTFILES_ENVIRONMENT:-default}"
}

dotfiles_nix_apply () {
  if [ "${DOTFILES_NIX_SKIP:-0}" -eq 1 ]; then
    log 'DOTFILES_NIX_SKIP set; skipping nix'
    return 0
  fi

  _dotfiles_nix_install
  _dotfiles_nix_load_profile

  if ! command -v nix >/dev/null 2>&1; then
    error 'nix is not available after install; aborting nix setup'
    return 1
  fi

  # The official Linux installer does not enable flakes by default, so pass the
  # experimental features explicitly. Harmless where already enabled (macOS).
  local -a nixflags=(--extra-experimental-features 'nix-command flakes')

  local profile
  profile="$(_dotfiles_nix_resolve_profile)"
  log "Resolved profile: $profile"

  # The username (from whoami) lives in an untracked, generated
  # core/host.nix so it stays out of git. The selected $profile picks
  # the env's flake dir below but is not written into host.nix.
  printf '# Generated by lib/nix — host-specific, not tracked in git.\n{ username = "%s"; }\n' \
    "$(whoami)" > "$DOTFILES_ROOT_DIR/core/host.nix"

  local system
  system="$(nix "${nixflags[@]}" eval --impure --raw --expr 'builtins.currentSystem')"

  # Fail fast on an empty system. Every flake ref below interpolates $system as
  # the attr key; an empty value would silently mis-target. It is especially
  # dangerous for the nix-darwin ref (`path:...#$system`): darwin-rebuild's
  # parser falls back to `darwinConfigurations.$(scutil --get LocalHostName)`
  # when the fragment is empty, which could activate the wrong config without
  # warning. currentSystem should never be empty, but guard before we build any
  # ref from it.
  if [ -z "$system" ]; then
    error 'Could not determine the current system (nix eval builtins.currentSystem returned empty).'
    return 1
  fi

  # Resolve the env's flake dir by the directory rule. A private env (under
  # custom_environments) wins over a public one of the same name. Every env is
  # built against the local core via `--override-input public path:.../core`,
  # which also makes the untracked host.nix visible.
  local flake_dir
  if [ -f "$DOTFILES_ROOT_DIR/custom_environments/$profile/flake.nix" ]; then
    flake_dir="$DOTFILES_ROOT_DIR/custom_environments/$profile"
  elif [ -f "$DOTFILES_ROOT_DIR/environments/$profile/flake.nix" ]; then
    flake_dir="$DOTFILES_ROOT_DIR/environments/$profile"
  else
    error "environment '$profile' is not buildable: no environments/$profile/flake.nix and no custom_environments/$profile/flake.nix"
    return 1
  fi
  log "Building environment '$profile' for $system"

  local tmpdir
  tmpdir="$(mktemp -d)"
  nix "${nixflags[@]}" build \
    "path:$flake_dir#homeConfigurations.\"$system\".activationPackage" \
    --override-input public "path:$DOTFILES_ROOT_DIR/core" \
    --out-link "$tmpdir/result"

  log 'Activating home-manager configuration'
  "$tmpdir/result/activate"

  # Clean up on the success path. A failed build/activate aborts under `set -e`
  # before this and leaks one small temp dir, which is an acceptable rare case.
  rm -rf "$tmpdir"

  # nix-darwin: macOS-only system layer. Runs after home-manager so the
  # user-level setup is in place when nix-darwin tries to resolve user
  # shells, etc. $system was set above (line ~116); reuse it rather than
  # re-evaluating `builtins.currentSystem` via a second nix subprocess.
  if [ "$(uname -s)" = "Darwin" ]; then
    # Build the selected env's own darwin config (keyed by bare "<system>").
    # The fragment after `#` must be the BARE config name (the system, e.g.
    # `aarch64-darwin`) — not `darwinConfigurations.<system>` and not quoted.
    # `darwin-rebuild` (used by both the `nix run nix-darwin -- switch`
    # bootstrap and the later `darwin-rebuild switch`) parses the ref itself:
    # it splits on `#` with the regex `^(.*)\#([^\#\"]*)$` (whose attr class
    # excludes `"`), then PREPENDS `darwinConfigurations.` and APPENDS `.system`
    # to whatever it captured. So a quoted system fails the regex (→ silent
    # fallback to `darwinConfigurations.$(hostname)`), and a `darwinConfigurations.`
    # prefix here gets doubled. Passing the bare system lets darwin-rebuild build
    # the correct `darwinConfigurations.<system>.system`. (The separate `nix
    # build` comparison below is NOT darwin-rebuild, so it keeps the full quoted
    # attr path.)
    local darwin_ref="path:$flake_dir#$system"

    # `sudo -H` resets $HOME to root's home (/var/root) for the duration of
    # the elevated command. Without it, nix-darwin sees $HOME=/Users/<user>
    # (inherited from the calling shell), warns "not owned by you", and
    # falls back to writing state (Nix config dir, etc.) under /var/root.
    # The fallback can cause repeated warnings and state drift across
    # applies — not strictly broken, but worth avoiding.
    #
    # The `path:` prefix on the flake ref tells nix to use a non-git fetcher
    # that includes the untracked host.nix. Plain `${flake_dir}#…` would use
    # git-tree semantics and miss host.nix entirely. `--override-input public
    # path:.../core` builds the env against the local core, matching
    # the home-manager build above.
    if ! command -v darwin-rebuild >/dev/null 2>&1; then
      log "Bootstrapping nix-darwin (first apply on this machine; sudo required)"
      sudo -H nix "${nixflags[@]}" run \
        nix-darwin -- switch --flake "$darwin_ref" \
        --override-input public "path:$DOTFILES_ROOT_DIR/core"
    else
      # `darwin-rebuild switch` always re-runs the whole activation: it prompts
      # for sudo, re-runs `brew bundle`, and restarts the Dock (nix-darwin's
      # user-defaults script kills the Dock whenever any dock default is set,
      # regardless of whether a dock value actually changed). To avoid that
      # churn on the common no-op apply, build the system derivation first
      # (unprivileged and cached, so cheap) and only switch when the result
      # differs from the running system. The build is deterministic and not
      # path-dependent, so an unchanged config reproduces /run/current-system
      # exactly.
      #
      # Skipping the switch also skips re-asserting declarative state, so a
      # managed default changed by hand (which leaves the system derivation
      # identical) won't be corrected until the config next changes. Set
      # DOTFILES_DARWIN_FORCE=1 to switch unconditionally and re-assert it.
      local do_switch=1
      if [ "${DOTFILES_DARWIN_FORCE:-0}" -eq 1 ]; then
        log "DOTFILES_DARWIN_FORCE set; forcing nix-darwin switch"
      else
        local built current
        built="$(nix "${nixflags[@]}" build --no-link --print-out-paths \
          "path:$flake_dir#darwinConfigurations.\"$system\".system" \
          --override-input public "path:$DOTFILES_ROOT_DIR/core")"
        # /run/current-system is a direct symlink to the active system's store
        # path (nix-darwin resolves it with `readlink -f` before linking), so a
        # single-level `readlink` returns the canonical path that matches
        # `nix build --print-out-paths`. Avoids `readlink -f`, which BSD readlink
        # (macOS /usr/bin) does not support.
        current="$(readlink /run/current-system 2>/dev/null || true)"
        if [ "$built" = "$current" ]; then
          do_switch=0
          log "nix-darwin system unchanged; skipping switch (no sudo, no Dock restart)"
        fi
      fi
      if [ "$do_switch" -eq 1 ]; then
        log "Activating nix-darwin (sudo required)"
        sudo -H darwin-rebuild switch --flake "$darwin_ref" \
          --override-input public "path:$DOTFILES_ROOT_DIR/core"
      fi
    fi
  fi
}
