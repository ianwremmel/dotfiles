#!/usr/bin/env bash

# Ensures Homebrew is installed. nix-darwin's homebrew module manages casks /
# mas apps / a few escape-hatched brews via `brew bundle`, but it does not
# install brew itself, so ./apply sources this and calls compat_ensure_homebrew
# on macOS before activating nix-darwin.
#
# (This file used to also bootstrap a modern Bash via `brew install bash`. That
# is gone — the framework-collapse slice made ./apply run on stock Bash 3.2.57,
# and Nix now provides the general-purpose Bash 5.)

compat_ensure_homebrew () {
  if ! command -v brew >/dev/null 2>&1; then
    echo "Homebrew not found. Installing"

    if [ -f /usr/local/bin/brew ]; then
      eval "$(/usr/local/bin/brew shellenv)"
    elif [ -f /opt/homebrew/bin/brew ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    else
      if [ ! -f ./Homebrew-4.4.21.pkg ]; then
          curl -O -L https://github.com/Homebrew/brew/releases/download/4.4.21/Homebrew-4.4.21.pkg
      fi
      sudo installer -pkg Homebrew-4.4.21.pkg -target /
    fi

    if [ -f /usr/local/bin/brew ]; then
      eval "$(/usr/local/bin/brew shellenv)"
    elif [ -f /opt/homebrew/bin/brew ]; then
      eval "$(/opt/homebrew/bin/brew shellenv)"
    else
      log 'Homebrew cannot be found. Something seems to have gone wrong during the install.'
      log 'Did you try to install it in a non-standard location?'
      exit 1
    fi

    brew analytics off

    echo "Homebrew installed"
  fi
}
