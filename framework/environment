#!/usr/bin/env bash

#
# Outputs the current environment
#
environment_get_current () {
  # A preset process env var wins (e.g. `DOTFILES_ENVIRONMENT=agent ./apply` on a
  # CI box), then the persisted value in ~/.dotfilesrc.
  local env
  env="${DOTFILES_ENVIRONMENT:-}"
  [ "$env" != '' ] || env="$(config_read DOTFILES_ENVIRONMENT)"

  if [ "$env" != '' ]; then
    debug "environment '$env' has already been set"
    echo "$env"
    return 0
  fi

  # No persisted environment and no tty to prompt on: refuse to guess. The
  # caller must set DOTFILES_ENVIRONMENT explicitly for non-interactive runs.
  if [ ! -t 0 ]; then
    error 'No environment set and stdin is not a TTY to prompt on.'
    error 'Set DOTFILES_ENVIRONMENT explicitly (e.g. DOTFILES_ENVIRONMENT=agent or DOTFILES_ENVIRONMENT=default).'
    return 1
  fi

  local candidates
  candidates="$(environment_list_all_environments)"

  # No buildable environment anywhere (a broken checkout missing default/agent).
  # Guard on emptiness directly: a `grep -c` here would exit 1 on zero matches
  # and abort under `set -euo pipefail` before this message could print.
  if [ "$candidates" = '' ]; then
    error 'No buildable environments found under environments/ or custom_environments/.'
    return 1
  fi

  local count
  count="$(printf '%s\n' "$candidates" | grep -c '^.')"

  # Exactly one buildable environment: use it without prompting, but persist it
  # so the active environment is recorded for later runs and the rest of the
  # system.
  if [ "$count" -eq 1 ]; then
    debug "single environment '$candidates' detected; using and persisting it"
    config_write DOTFILES_ENVIRONMENT "$candidates"
    echo "$candidates"
    return 0
  fi

  echo 'Multiple environments detected. Which would you like to apply to this device?'
  select env in $candidates; do
    debug "Storing user-selected environment '$env'"
    config_write DOTFILES_ENVIRONMENT "$env"
    echo "$env"
    # Without the break, the select just loops forever.
    break
  done

}

#
# Lists every buildable environment, one basename per line, sorted.
#
# Directory rule: an environment is the basename of any directory directly
# under `environments/` or `custom_environments/` that contains a `flake.nix`.
# `environments/default` and `environments/agent` qualify; `environments/all`
# (no flake.nix) does not, and the top-level `environments/flake.nix` is not a
# subdir so it is not a candidate.
#
environment_list_all_environments () {
  local d
  for d in "$DOTFILES_ROOT_DIR"/environments/*/ \
           "$DOTFILES_ROOT_DIR"/custom_environments/*/; do
    # Guards both the unmatched-glob literal (e.g. `.../custom_environments/*/`
    # when the dir is empty/absent) and any non-directory.
    [ -d "$d" ] || continue
    [ -f "${d}flake.nix" ] || continue
    basename "$d"
  done | sort -u
}
