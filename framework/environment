#!/usr/bin/env bash

#
# Outputs the current environment
#
environment_get_current () {
  local env
  env="$(config_read DOTFILES_ENVIRONMENT)"

  if [ "$env" != '' ]; then
    debug "environment '$env' has already been set"
    echo "$env"
    return 0
  fi

  local non_default_envs=''

  for env in $(environment_list_all_environments); do
    if [ "$env" == 'all' ]; then
      continue
    fi

    non_default_envs+="$env "
  done

  # Default when the only environment is `default`, OR when none exist at all
  # (the public `environments/` tree was fully migrated into nix/, so a fresh
  # machine with no custom_environments has nothing to choose from — fall back
  # to `default` rather than presenting an empty `select` prompt).
  if [ "$non_default_envs" == 'default ' ] || [ "$non_default_envs" == '' ]; then
    debug 'no selectable environments detected, choosing default'
    echo 'default'
    return 0
  fi

  echo 'Multiple environments detected. Which would you like to apply to this device?'
  select env in $non_default_envs; do
    debug "Storing user-selected environment '$env'"
    config_write DOTFILES_ENVIRONMENT "$env"
    echo "$env"
    # Without the break, the select just loops forever.
    break
  done

}

#
# Lists every environment that exists (public + custom), excluding `all`.
# Used by environment_get_current to decide whether to prompt.
#
environment_list_all_environments () {
  # shellcheck disable=SC2012
  local envs=''
  # The public `environments/` tree no longer exists (its content migrated into
  # nix/); guard the listing so a missing dir doesn't print a spurious `ls`
  # error. Only `custom_environments/<env>` remains as a real source.
  [ -d "$DOTFILES_ROOT_DIR/environments" ] && envs="$(ls "$DOTFILES_ROOT_DIR/environments")"
  if [ -d "$DOTFILES_ROOT_DIR/custom_environments" ]; then
    envs="$envs
$(ls "$DOTFILES_ROOT_DIR/custom_environments")"
  fi

  # -vx: exact whole-line match, so an env whose name merely contains "all"
  # (e.g. "fallback") isn't filtered out with the real "all". Drop blank lines.
  printf '%s\n' "$envs" | sort | uniq | grep -vx all | grep -v '^$'
}
