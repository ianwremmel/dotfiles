#!/usr/bin/env bash

# Flat, Bash-3.2-safe entrypoint. Runs start-to-finish in the invoking shell
# (no self re-exec) so it works under stock macOS /bin/bash 3.2.57. Nix
# provides a general-purpose Bash 5 via home.packages for everything else.

set -euo pipefail

export DOTFILES_ROOT_DIR
DOTFILES_ROOT_DIR="$(cd "$(dirname "$0")" >/dev/null 2>&1 && pwd)"

while getopts "h?" opt; do
  case $opt in
    ?)  echo "Usage: $(basename "$0") [-h|-?]"
        echo "-h|-?   Print this help and exit"
        exit 2;;
  esac
done

source ./framework/logging
source ./framework/config
source ./framework/environment
source ./lib/nix

# The framework helpers expect ~/.dotfilesrc to exist (config_read/_write).
# Mode 0600 matches the historical first-run permissions.
[ -f "$HOME/.dotfilesrc" ] || install -m 0600 /dev/null "$HOME/.dotfilesrc"

# Resolve (and, when multiple environments exist, prompt for + persist) the
# active environment, then export it (and anything else in ~/.dotfilesrc).
environment_get_current
config_load

if [ "$(uname -s)" = Darwin ]; then
  # nix-darwin's homebrew module runs `brew bundle` on activate but does NOT
  # install brew itself — ensure it is present first.
  source ./framework/compat
  compat_ensure_homebrew
fi

# Install nix, generate core/host.nix, build + activate home-manager, and (on
# macOS) activate nix-darwin.
dotfiles_nix_apply

echo ''
echo 'Please reload your shell to apply changes'
echo ''
